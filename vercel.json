{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ],
  "crons": [
    {
      "path": "/api/cron-alerts",
      "schedule": "10 7 * * *"
    },
    {
      "path": "/api/cron-alerts",
      "schedule": "30 10 * * *"
    }
  ]
}
